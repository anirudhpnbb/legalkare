# LegalKare Environment Variables Template
# Copy this file to .env and fill in your actual values

# OpenAI Configuration
OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o-mini

# Indian Khanoon Configuration
SOURCE_DB_TOKEN=your_source_db_token_here

# MongoDB Configuration
MONGO_CLIENT=mongodb://localhost:27017
# Or for MongoDB Atlas:
# MONGO_CLIENT=mongodb+srv://username:password@cluster.mongodb.net/database

# AWS Cognito Client Configuration
REGION=ap-south-1
SERVICE_NAME=cognito-idp
COGNITO_CLIENT_ID=your_cognito_client_id_here
COGNITO_CLIENT_SECRET=your_cognito_client_secret_here

# AWS S3 Configuration
S3_BUCKET_NAME=your_s3_bucket_name_here
S3_ACCESS_KEY_ID=your_s3_access_key_id_here
S3_ACCESS_SECRET_TOKEN=your_s3_secret_access_key_here

# AWS SES Configuration
AWS_SES_REGION=ap-south-1
AWS_SES_ACCESS_KEY_ID=your_ses_access_key_id_here
AWS_SES_SECRET_ACCESS_KEY=your_ses_secret_access_key_here
AWS_SES_SOURCE_EMAIL=your_verified_email@yourdomain.com

# Twilio Configuration
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_API_KEY_SID=your_twilio_api_key_sid_here
TWILIO_API_KEY_SECRET=your_twilio_api_key_secret_here

# Model Configuration
EMBEDDING_MODEL_NAME=all-MiniLM-L6-v2
INDEX_FOLDER=index.faiss
METADATA_FOLDER=metadata.json
SEGMENT_SIZE=100000

# API Configuration
SUMMARIZATION_API_URL=http://127.0.0.1:5002/summarise
FLASK_API_URL=http://127.0.0.1:5002/profile/view_appointments

# Document Repository
DOCUMENTS_DIR=ik_downloads/
DOCS_FOLDER=ik_downloads/

# Flask Session Configuration
SECRET_KEY_FLASK=your_flask_secret_key_here

# Encryption Key (32 url-safe base64-encoded bytes)
ENCRYPTION_KEY=your_encryption_key_here

# Stripe Configuration (if using payments)
STRIPE_SECRET_KEY=your_stripe_secret_key_here
PAYMENT_SUCCESS_URL=https://your-domain.com/whatsapp/payment_success
PAYMENT_CANCEL_URL=https://your-domain.com/payment_cancel